<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RecipeStudio.Desktop.Views.Pages.SettingsView">

  <Grid ColumnDefinitions="290,*" Margin="18">

    <Border Grid.Column="0" Classes="card" Padding="12">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="10">
          <TextBlock Text="Настройки системы" Classes="h1" />
          <TextBlock Text="Навигация по разделам" Classes="muted" />

          <TreeView SelectionChanged="SettingsTree_SelectionChanged">
            <TreeViewItem Header="Система" IsExpanded="True">
              <TreeViewItem Header="Хранилище" Tag="storage" />
              <TreeViewItem Header="Параметры станка" Tag="machine" />
              <TreeViewItem Header="Коэффициенты" Tag="coefficients" />
              <TreeViewItem Header="Графика" Tag="graphics" />
              <TreeViewItem Header="Логирование" Tag="logging" />
            </TreeViewItem>
          </TreeView>
        </StackPanel>

        <!--
        <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,16,0,0">
          <TextBlock Text="Файлы приложения" FontWeight="SemiBold" />
          <StackPanel Spacing="2">
            <TextBlock Text="Файл настроек:" Classes="muted tiny" />
            <TextBlock Text="{Binding SettingsFilePath}" TextWrapping="Wrap" ToolTip.Tip="Путь к settings.json" />
          </StackPanel>
          <StackPanel Spacing="2">
            <TextBlock Text="Файл БД рецептов:" Classes="muted tiny" />
            <TextBlock Text="{Binding DatabaseFilePath}" TextWrapping="Wrap" ToolTip.Tip="Путь к SQLite базе recipes.sqlite" />
          </StackPanel>
        </StackPanel>
        -->
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" Margin="12,0,0,0" RowDefinitions="Auto,*">
      <Border Grid.Row="0" Classes="card">
        <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
          <TextBlock Text="{Binding CurrentSectionTitle}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
          <Button Grid.Column="1" Command="{Binding ResetToDefaultsCommand}" Classes="ghost" Margin="0,0,8,0" ToolTip.Tip="Сбросить все настройки к стандартным значениям">Сбросить</Button>
          <Button Grid.Column="2" Command="{Binding SaveCommand}" Classes="accent" ToolTip.Tip="Сохранить все изменения">Сохранить</Button>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
        <StackPanel Spacing="16">

          <Border Classes="card" IsVisible="{Binding IsStorageSection}">
            <StackPanel Spacing="10">
              <TextBlock Text="Папка хранения" Classes="muted" Margin="0,0,0,4" />

              <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Name="RecipesFolderTextBox"
                         Grid.Column="0"
                         Text="{Binding RecipesFolder}"
                         ToolTip.Tip="Путь к папке с рецептами и SQLite базой. Двойной клик открывает каталог" />

                <Button Grid.Column="1"
                        Click="OpenFolder_Click"
                        Classes="ghost"
                        Margin="8,0,0,0"
                        Width="40"
                        Height="34"
                        FontSize="16"
                        ToolTip.Tip="Открыть текущий каталог рецептов">
                  📂
                </Button>

                <Button Grid.Column="2"
                        Click="BrowseFolder_Click"
                        Classes="ghost"
                        Margin="8,0,0,0"
                        Width="40"
                        Height="34"
                        FontSize="16"
                        ToolTip.Tip="Выбрать другую папку рецептов">
                  🗁
                </Button>
              </Grid>

              <CheckBox IsChecked="{Binding AutoCreateSampleRecipeOnEmpty}" Margin="0,8,0,0" ToolTip.Tip="Если база рецептов пуста при старте, автоматически создать образец H340_KAMA_1">Автоматически создавать образец рецепта при пустой базе</CheckBox>

              <Button Command="{Binding CreateSampleRecipeCommand}" Classes="ghost" HorizontalAlignment="Left" Margin="0,6,0,0" ToolTip.Tip="Создать образец рецепта H340_KAMA_1 вручную">Создать образец рецепта</Button>
            </StackPanel>
          </Border>

          <Border Classes="card" IsVisible="{Binding IsMachineSection}">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,*">
                <Border Classes="card" Padding="12">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Геометрия и смещения" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto">
                      <TextBlock Text="Смещение X (Xm)" VerticalAlignment="Center" ToolTip.Tip="Смещение по оси X, мм" Margin="0,0,0,8" />
                      <TextBox Grid.Column="1" Classes="value-box" Text="{Binding Xm}" Margin="10,0,0,8" ToolTip.Tip="Смещение по оси X, мм" />

                      <TextBlock Grid.Row="1" Text="Смещение Y (Ym)" VerticalAlignment="Center" ToolTip.Tip="Смещение по оси Y, мм" Margin="0,0,0,8" />
                      <TextBox Grid.Row="1" Grid.Column="1" Classes="value-box" Text="{Binding Ym}" Margin="10,0,0,8" ToolTip.Tip="Смещение по оси Y, мм" />

                      <TextBlock Grid.Row="2" Text="Смещение Z (Zm)" VerticalAlignment="Center" ToolTip.Tip="Смещение по оси Z, мм" Margin="0,0,0,8" />
                      <TextBox Grid.Row="2" Grid.Column="1" Classes="value-box" Text="{Binding Zm}" Margin="10,0,0,8" ToolTip.Tip="Смещение по оси Z, мм" />

                      <TextBlock Grid.Row="3" Text="Длина сопла (Lz)" VerticalAlignment="Center" ToolTip.Tip="Длина сопла, мм" />
                      <TextBox Grid.Row="3" Grid.Column="1" Classes="value-box" Text="{Binding Lz}" Margin="10,0,0,0" ToolTip.Tip="Длина сопла, мм" />
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="12" Margin="12,0,0,0">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Безопасность и зоны" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto">
                      <TextBlock Text="Высота перехода (H_cont)" VerticalAlignment="Center" ToolTip.Tip="Максимальная высота контейнера, мм" Margin="0,0,0,8" />
                      <TextBox Grid.Column="1" Classes="value-box" Text="{Binding HContMax}" Margin="10,0,0,8" ToolTip.Tip="Максимальная высота контейнера, мм" />

                      <TextBlock Grid.Row="1" Text="Зона безопасности (H_zone)" VerticalAlignment="Center" ToolTip.Tip="Зазор между столом и фланцем, мм" Margin="0,0,0,8" />
                      <TextBox Grid.Row="1" Grid.Column="1" Classes="value-box" Text="{Binding HZone}" Margin="10,0,0,8" ToolTip.Tip="Зазор между столом и фланцем, мм" />

                      <TextBlock Grid.Row="2" Text="Боковой предел (H_bok)" VerticalAlignment="Center" ToolTip.Tip="Максимальная толщина крышки, мм" Margin="0,0,0,8" />
                      <TextBox Grid.Row="2" Grid.Column="1" Classes="value-box" Text="{Binding HBokMax}" Margin="10,0,0,8" ToolTip.Tip="Максимальная толщина крышки, мм" />

                      <TextBlock Grid.Row="3" Text="Нейтральная плоскость (H_freeZ)" VerticalAlignment="Center" ToolTip.Tip="Высота от стола до промежуточной нейтральной плоскости между контейнером и крышкой, мм" />
                      <TextBox Grid.Row="3" Grid.Column="1" Classes="value-box" Text="{Binding HFreeZ}" Margin="10,0,0,0" ToolTip.Tip="Высота от стола до промежуточной нейтральной плоскости между контейнером и крышкой, мм" />
                    </Grid>
                  </StackPanel>
                </Border>
              </Grid>

              <Border Classes="card" Padding="12">
                <StackPanel Spacing="10">
                  <TextBlock Text="Ориентация сопла (A/B)" FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Text="Режим ориентации" VerticalAlignment="Center" ToolTip.Tip="physical_angles: только по углам A/B; target_tracking: доворот сопла на цель" Margin="0,0,0,8" />
                    <ComboBox Grid.Column="1"
                              Classes="value-box"
                              ItemsSource="{Binding NozzleOrientationModeOptions}"
                              SelectedValue="{Binding NozzleOrientationMode}"
                              SelectedValueBinding="{Binding Value}"
                              Margin="10,0,0,8"
                              ToolTip.Tip="physical_angles: только по углам A/B; target_tracking: доворот сопла на цель">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,0,0,8" Text="{Binding NozzleOrientationModeDescription}" Classes="muted tiny" TextWrapping="Wrap" />

                    <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="220,*,*,*,*" RowDefinitions="Auto,Auto" Margin="0,2,0,0">
                      <TextBlock Text="Диапазоны углов, °" VerticalAlignment="Center" ToolTip.Tip="Физические ограничения для режима physical_angles" />
                      <TextBlock Grid.Column="1" Text="A min" Margin="10,0,0,6" />
                      <TextBlock Grid.Column="2" Text="A max" Margin="10,0,0,6" />
                      <TextBlock Grid.Column="3" Text="B min" Margin="10,0,0,6" />
                      <TextBlock Grid.Column="4" Text="B max" Margin="10,0,0,6" />

                      <TextBox Grid.Row="1" Grid.Column="1" Classes="value-box" Text="{Binding AlfaMinDeg}" Margin="10,0,0,0" ToolTip.Tip="Минимальный угол A (обычно -90)" />
                      <TextBox Grid.Row="1" Grid.Column="2" Classes="value-box" Text="{Binding AlfaMaxDeg}" Margin="10,0,0,0" ToolTip.Tip="Максимальный угол A (обычно +90)" />
                      <TextBox Grid.Row="1" Grid.Column="3" Classes="value-box" Text="{Binding BettaMinDeg}" Margin="10,0,0,0" ToolTip.Tip="Минимальный угол B (обычно -15)" />
                      <TextBox Grid.Row="1" Grid.Column="4" Classes="value-box" Text="{Binding BettaMaxDeg}" Margin="10,0,0,0" ToolTip.Tip="Максимальный угол B (обычно +15)" />
                    </Grid>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="card" IsVisible="{Binding IsCoefficientsSection}">
            <StackPanel Spacing="10">
              <TextBlock Text="Импульсов на мм. Параметры используются для пересчёта траекторий." Classes="muted" />

              <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Text="VPULSE_X" ToolTip.Tip="Коэффициент импульсов по оси X" Margin="0,0,0,6" />
                <TextBlock Grid.Column="1" Text="VPULSE_Y" Margin="12,0,0,6" ToolTip.Tip="Коэффициент импульсов по оси Y" />
                <TextBlock Grid.Column="2" Text="VPULSE_Z" Margin="12,0,0,6" ToolTip.Tip="Коэффициент импульсов по оси Z" />
                <TextBlock Grid.Column="3" Text="VPULSE_A" Margin="12,0,0,6" ToolTip.Tip="Коэффициент импульсов по оси A" />

                <TextBox Grid.Row="1" Classes="value-box" Text="{Binding PulseX}" Margin="0,0,0,10" ToolTip.Tip="Коэффициент импульсов по оси X" />
                <TextBox Grid.Row="1" Grid.Column="1" Classes="value-box" Text="{Binding PulseY}" Margin="12,0,0,10" ToolTip.Tip="Коэффициент импульсов по оси Y" />
                <TextBox Grid.Row="1" Grid.Column="2" Classes="value-box" Text="{Binding PulseZ}" Margin="12,0,0,10" ToolTip.Tip="Коэффициент импульсов по оси Z" />
                <TextBox Grid.Row="1" Grid.Column="3" Classes="value-box" Text="{Binding PulseA}" Margin="12,0,0,10" ToolTip.Tip="Коэффициент импульсов по оси A" />

                <TextBlock Grid.Row="2" Text="VPULSE_B" ToolTip.Tip="Коэффициент импульсов по оси B" Margin="0,0,0,6" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="VPULSE_TOP" Margin="12,0,0,6" ToolTip.Tip="Коэффициент импульсов одного оборота TOP" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="VPULSE_LOW" Margin="12,0,0,6" ToolTip.Tip="Коэффициент импульсов одного оборота LOW" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="VPULSE_CLAMP" Margin="12,0,0,6" ToolTip.Tip="Коэффициент импульсов одного оборота зажима" />

                <TextBox Grid.Row="3" Classes="value-box" Text="{Binding PulseB}" ToolTip.Tip="Коэффициент импульсов по оси B" />
                <TextBox Grid.Row="3" Grid.Column="1" Classes="value-box" Text="{Binding PulseTop}" Margin="12,0,0,0" ToolTip.Tip="Коэффициент импульсов одного оборота TOP" />
                <TextBox Grid.Row="3" Grid.Column="2" Classes="value-box" Text="{Binding PulseLow}" Margin="12,0,0,0" ToolTip.Tip="Коэффициент импульсов одного оборота LOW" />
                <TextBox Grid.Row="3" Grid.Column="3" Classes="value-box" Text="{Binding PulseClamp}" Margin="12,0,0,0" ToolTip.Tip="Коэффициент импульсов одного оборота зажима" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="card" IsVisible="{Binding IsGraphicsSection}">
            <StackPanel Spacing="14">
              <Grid ColumnDefinitions="220,*,70">
                <TextBlock Text="Прозрачность линии" VerticalAlignment="Center" ToolTip.Tip="Прозрачность кривой на графике (0.05–0.90)" />
                <Slider Grid.Column="1" Minimum="0.05" Maximum="0.90" Value="{Binding PlotOpacity}" Margin="10,0,10,0" ToolTip.Tip="Прозрачность кривой на графике (0.05–0.90)" />
                <TextBlock Grid.Column="2" Text="{Binding PlotOpacityDisplay}" VerticalAlignment="Center" HorizontalAlignment="Right" />
              </Grid>

              <Grid ColumnDefinitions="*,*">
                <Border Classes="card" Padding="12">
                  <StackPanel Spacing="10">
                    <CheckBox IsChecked="{Binding PlotShowPolyline}" ToolTip.Tip="Показывать ломаную линию исходных точек">Показывать ломаную (polyline)</CheckBox>
                    <CheckBox IsChecked="{Binding PlotShowSmooth}" ToolTip.Tip="Показывать сглаженную кривую">Показывать сглаженную линию (spline)</CheckBox>
                    <CheckBox IsChecked="{Binding PlotShowTargetPoints}" ToolTip.Tip="Показывать целевые точки рецепта">Показывать точки</CheckBox>
                    <CheckBox IsChecked="{Binding PlotEnableDrag}" ToolTip.Tip="Разрешить перетаскивание точек мышью на графике">Разрешить перетаскивание точек на графике</CheckBox>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="12" Margin="12,0,0,0">
                  <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
                    <TextBlock Text="Толщина линии" VerticalAlignment="Center" ToolTip.Tip="Толщина основной линии графика" Margin="0,0,0,10" />
                    <TextBox Grid.Column="1" Classes="value-box" Text="{Binding PlotStrokeThickness}" Margin="10,0,0,10" ToolTip.Tip="Толщина основной линии графика" />

                    <TextBlock Grid.Row="1" Text="Радиус точек" VerticalAlignment="Center" ToolTip.Tip="Размер отображаемых точек на графике" Margin="0,0,0,10" />
                    <TextBox Grid.Row="1" Grid.Column="1" Classes="value-box" Text="{Binding PlotPointRadius}" Margin="10,0,0,10" ToolTip.Tip="Размер отображаемых точек на графике" />

                    <TextBlock Grid.Row="2" Text="Сегменты сглаживания" VerticalAlignment="Center" ToolTip.Tip="Чем выше значение, тем более плавная кривая и выше нагрузка" />
                    <TextBox Grid.Row="2" Grid.Column="1" Classes="value-box" Text="{Binding SmoothSegmentsPerSpan}" Margin="10,0,0,0" ToolTip.Tip="Чем выше значение, тем более плавная кривая и выше нагрузка" />
                  </Grid>
                </Border>
              </Grid>

              <Border Classes="card" Padding="12">
                <StackPanel Spacing="10">
                  <TextBlock Text="Цвета графика" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="Можно вводить HEX вручную или выбирать пресеты кнопками справа." Classes="muted tiny" />

                  <Grid ColumnDefinitions="180,*,34,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,4,0,0">
                    <TextBlock Text="Рабочая зона" VerticalAlignment="Center" Margin="0,0,0,10" />
                    <TextBox Grid.Column="1" Classes="value-box" Text="{Binding PlotColorWorkingZone}" Margin="10,0,0,10" />
                    <Border Grid.Column="2" Margin="8,2,0,12" CornerRadius="4" BorderBrush="#4B5563" BorderThickness="1" Background="{Binding PlotColorWorkingZone}" />
                    <Button Grid.Column="3" Width="30" Height="24" Margin="8,0,0,10" Classes="ghost" Content="🎨" Tag="PlotColorWorkingZone" Click="ColorPicker_Click" ToolTip.Tip="Выбрать любой цвет" />
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" Margin="10,0,0,10">
                      <Button Width="24" Height="24" Background="#22C55E" Tag="PlotColorWorkingZone:#22C55E" Click="ColorPreset_Click" ToolTip.Tip="Зеленый" />
                      <Button Width="24" Height="24" Background="#3B82F6" Tag="PlotColorWorkingZone:#3B82F6" Click="ColorPreset_Click" ToolTip.Tip="Синий" />
                      <Button Width="24" Height="24" Background="#A855F7" Tag="PlotColorWorkingZone:#A855F7" Click="ColorPreset_Click" ToolTip.Tip="Фиолетовый" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Safe-зона" VerticalAlignment="Center" Margin="0,0,0,10" />
                    <TextBox Grid.Row="1" Grid.Column="1" Classes="value-box" Text="{Binding PlotColorSafetyZone}" Margin="10,0,0,10" />
                    <Border Grid.Row="1" Grid.Column="2" Margin="8,2,0,12" CornerRadius="4" BorderBrush="#4B5563" BorderThickness="1" Background="{Binding PlotColorSafetyZone}" />
                    <Button Grid.Row="1" Grid.Column="3" Width="30" Height="24" Margin="8,0,0,10" Classes="ghost" Content="🎨" Tag="PlotColorSafetyZone" Click="ColorPicker_Click" ToolTip.Tip="Выбрать любой цвет" />
                    <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="4" Margin="10,0,0,10">
                      <Button Width="24" Height="24" Background="#9CA3AF" Tag="PlotColorSafetyZone:#9CA3AF" Click="ColorPreset_Click" ToolTip.Tip="Серый" />
                      <Button Width="24" Height="24" Background="#6B7280" Tag="PlotColorSafetyZone:#6B7280" Click="ColorPreset_Click" ToolTip.Tip="Тёмно-серый" />
                      <Button Width="24" Height="24" Background="#CBD5E1" Tag="PlotColorSafetyZone:#CBD5E1" Click="ColorPreset_Click" ToolTip.Tip="Светло-серый" />
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Робот/траектория" VerticalAlignment="Center" Margin="0,0,0,10" />
                    <TextBox Grid.Row="2" Grid.Column="1" Classes="value-box" Text="{Binding PlotColorRobotPath}" Margin="10,0,0,10" />
                    <Border Grid.Row="2" Grid.Column="2" Margin="8,2,0,12" CornerRadius="4" BorderBrush="#4B5563" BorderThickness="1" Background="{Binding PlotColorRobotPath}" />
                    <Button Grid.Row="2" Grid.Column="3" Width="30" Height="24" Margin="8,0,0,10" Classes="ghost" Content="🎨" Tag="PlotColorRobotPath" Click="ColorPicker_Click" ToolTip.Tip="Выбрать любой цвет" />
                    <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" Spacing="4" Margin="10,0,0,10">
                      <Button Width="24" Height="24" Background="#F59E0B" Tag="PlotColorRobotPath:#F59E0B" Click="ColorPreset_Click" ToolTip.Tip="Оранжевый" />
                      <Button Width="24" Height="24" Background="#EAB308" Tag="PlotColorRobotPath:#EAB308" Click="ColorPreset_Click" ToolTip.Tip="Жёлтый" />
                      <Button Width="24" Height="24" Background="#F97316" Tag="PlotColorRobotPath:#F97316" Click="ColorPreset_Click" ToolTip.Tip="Ярко-оранжевый" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="Связи" VerticalAlignment="Center" Margin="0,0,0,10" />
                    <TextBox Grid.Row="3" Grid.Column="1" Classes="value-box" Text="{Binding PlotColorPairLinks}" Margin="10,0,0,10" />
                    <Border Grid.Row="3" Grid.Column="2" Margin="8,2,0,12" CornerRadius="4" BorderBrush="#4B5563" BorderThickness="1" Background="{Binding PlotColorPairLinks}" />
                    <Button Grid.Row="3" Grid.Column="3" Width="30" Height="24" Margin="8,0,0,10" Classes="ghost" Content="🎨" Tag="PlotColorPairLinks" Click="ColorPicker_Click" ToolTip.Tip="Выбрать любой цвет" />
                    <StackPanel Grid.Row="3" Grid.Column="4" Orientation="Horizontal" Spacing="4" Margin="10,0,0,10">
                      <Button Width="24" Height="24" Background="#FB923C" Tag="PlotColorPairLinks:#FB923C" Click="ColorPreset_Click" ToolTip.Tip="Оранжевый" />
                      <Button Width="24" Height="24" Background="#F43F5E" Tag="PlotColorPairLinks:#F43F5E" Click="ColorPreset_Click" ToolTip.Tip="Розовый" />
                      <Button Width="24" Height="24" Background="#14B8A6" Tag="PlotColorPairLinks:#14B8A6" Click="ColorPreset_Click" ToolTip.Tip="Бирюзовый" />
                    </StackPanel>

                    <TextBlock Grid.Row="4" Text="Инструмент" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="1" Classes="value-box" Text="{Binding PlotColorTool}" Margin="10,0,0,0" />
                    <Border Grid.Row="4" Grid.Column="2" Margin="8,2,0,2" CornerRadius="4" BorderBrush="#4B5563" BorderThickness="1" Background="{Binding PlotColorTool}" />
                    <Button Grid.Row="4" Grid.Column="3" Width="30" Height="24" Margin="8,0,0,0" Classes="ghost" Content="🎨" Tag="PlotColorTool" Click="ColorPicker_Click" ToolTip.Tip="Выбрать любой цвет" />
                    <StackPanel Grid.Row="4" Grid.Column="4" Orientation="Horizontal" Spacing="4" Margin="10,0,0,0">
                      <Button Width="24" Height="24" Background="#EF4444" Tag="PlotColorTool:#EF4444" Click="ColorPreset_Click" ToolTip.Tip="Красный" />
                      <Button Width="24" Height="24" Background="#DC2626" Tag="PlotColorTool:#DC2626" Click="ColorPreset_Click" ToolTip.Tip="Тёмно-красный" />
                      <Button Width="24" Height="24" Background="#F472B6" Tag="PlotColorTool:#F472B6" Click="ColorPreset_Click" ToolTip.Tip="Розовый" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="card" IsVisible="{Binding IsLoggingSection}">
            <StackPanel Spacing="12">
              <TextBlock Text="Параметры логирования" FontSize="16" FontWeight="SemiBold" />

              <CheckBox IsChecked="{Binding LoggingEnabled}" ToolTip.Tip="Включить или выключить запись в файл логов">Включить запись логов в файл</CheckBox>

              <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Text="Режим логирования" VerticalAlignment="Center" ToolTip.Tip="Info — все сообщения, Warning — предупреждения и ошибки, Error — только ошибки" />
                <ComboBox Grid.Column="1" Margin="10,0,0,0" ItemsSource="{Binding LogModes}" SelectedItem="{Binding LogMode}" ToolTip.Tip="Выбор фильтра логов: Info/Warning/Error" />

                <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,6,0,0" Text="{Binding LogModeDescription}" Classes="muted tiny" TextWrapping="Wrap" />

                <TextBlock Grid.Row="2" Text="Хранить логи (дней)" VerticalAlignment="Center" Margin="0,8,0,0" ToolTip.Tip="Текущий день + предыдущие дни по значению" />
                <TextBox Grid.Row="2" Grid.Column="1" Classes="value-box" Text="{Binding LogRetentionDays}" Margin="10,8,0,0" ToolTip.Tip="От 1 до 3650 дней" />

                <TextBlock Grid.Row="3" Text="Файл лога за сегодня" VerticalAlignment="Center" Margin="0,8,0,0" ToolTip.Tip="Логи хранятся по дням: dd.MM.yyyy.log" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding LogFilePath}" Margin="10,8,0,0" IsReadOnly="True" />
              </Grid>

              <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding LogsFolder}"
                         Name="LogsFolderTextBox"
                         ToolTip.Tip="Папка с ежедневными лог-файлами" />

                <Button Grid.Column="1"
                        Click="OpenLogsFolder_Click"
                        Classes="ghost"
                        Margin="8,0,0,0"
                        Width="40"
                        Height="34"
                        FontSize="16"
                        ToolTip.Tip="Открыть папку логов">
                  📂
                </Button>

                <Button Grid.Column="2"
                        Click="BrowseLogsFolder_Click"
                        Classes="ghost"
                        Margin="8,0,0,0"
                        Width="40"
                        Height="34"
                        FontSize="16"
                        ToolTip.Tip="Выбрать папку для логов">
                  🗁
                </Button>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>

  </Grid>
</UserControl>
