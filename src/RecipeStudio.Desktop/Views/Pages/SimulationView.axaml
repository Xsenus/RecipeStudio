<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RecipeStudio.Desktop.Controls"
             x:Class="RecipeStudio.Desktop.Views.Pages.SimulationView">

  <Grid Margin="18" RowDefinitions="Auto,*" RowSpacing="12">
    <Border Classes="card" Padding="14">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <StackPanel>
          <TextBlock Text="Симуляция процесса" Classes="h1"/>
          <TextBlock Text="{Binding RecipePath}" Classes="muted" />
          <TextBlock Text="{Binding NozzleAngleWarning}" Foreground="#FCA5A5" FontSize="11" IsVisible="{Binding HasNozzleAngleWarning}" />
        </StackPanel>

        <Button Grid.Column="1" Command="{Binding StepPreviousCommand}" Classes="ghost" VerticalAlignment="Center">⏮</Button>
        <Button Grid.Column="2" Command="{Binding PlayPauseCommand}" Classes="accent" VerticalAlignment="Center">▶ / ❚❚</Button>
        <Button Grid.Column="3" Command="{Binding StopCommand}" Classes="ghost" VerticalAlignment="Center">⏹</Button>
        <Button Grid.Column="4" Command="{Binding StepNextCommand}" Classes="ghost" VerticalAlignment="Center">⏭</Button>

        <ToggleButton Grid.Column="5" IsChecked="{Binding ShowPairLinks}" Classes="ghost" VerticalAlignment="Center">Сетка точек</ToggleButton>
        <ToggleButton Grid.Column="6" IsChecked="{Binding ShowGrid}" Classes="ghost" VerticalAlignment="Center">Фон. сетка</ToggleButton>

        <ToggleButton Grid.Column="7" IsChecked="{Binding IncludeSafePoints}" Classes="ghost" VerticalAlignment="Center">Safe в анимации</ToggleButton>
        <ToggleButton Grid.Column="8" IsChecked="{Binding SmoothMotion}" Classes="ghost" VerticalAlignment="Center">Плавная траектория</ToggleButton>
        <ToggleButton Grid.Column="9" IsChecked="{Binding UsePhysicalNozzleOrientation}" Classes="ghost" VerticalAlignment="Center" ToolTip.Tip="Выкл: сопло наводится на текущую цель, вкл: ориентация только по A/B">A/B физика</ToggleButton>

        <Button Grid.Column="10" Command="{Binding ResetRecommendedModesCommand}" Classes="ghost" VerticalAlignment="Center">Reset Modes</Button>
        <StackPanel Grid.Column="11" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="Скорость" Classes="muted" VerticalAlignment="Center"/>
          <Slider Minimum="0.2" Maximum="12" Width="140" Value="{Binding SpeedMultiplier}" />
        </StackPanel>

        <StackPanel Grid.Column="12" VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="{Binding ProgressPercent, StringFormat='Прогресс: {0}%'}" />
          <TextBlock Text="{Binding CurrentStepIndex, StringFormat='Шаг: {0}'}" Classes="muted" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Canvas x:Name="PanelsCanvas" ClipToBounds="True">
        <Border x:Name="PlotPanel" Classes="card floating-panel" Width="700" Height="640" MinWidth="520" MinHeight="340"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*" RowSpacing="8" ClipToBounds="True">
            <Grid x:Name="PlotPanelHeader" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="PROFILE VIEWER (R-Z)" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Classes="ghost" ToolTip.Tip="Приблизить график" Click="ZoomInPlot_Click">＋</Button>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Отдалить график" Click="ZoomOutPlot_Click">－</Button>
                <Button Classes="ghost" ToolTip.Tip="Подогнать в окно" Click="FitPlot_Click">Fit</Button>
                <ToggleButton Classes="ghost"
                              ToolTip.Tip="Mirror left/right in profile"
                              IsChecked="{Binding ElementName=RecipePlot, Path=InvertHorizontal, Mode=TwoWay}">Mirror X</ToggleButton>
                <TextBlock x:Name="ZoomText" Text="x1.00" Classes="muted" VerticalAlignment="Center" />
                <Button Classes="ghost panel-close-btn" Click="HidePlotPanel_Click">✕</Button>
              </StackPanel>
            </Grid>

            <controls:RecipePlotControl Grid.Row="1" x:Name="RecipePlot"
                                        InvertHorizontal="True"
                                        Points="{Binding PointsForPlot}"
                                        AnimationPoints="{Binding PointsForAnimation}"
                                        Progress="{Binding Progress}"
                                        CurrentAlfa="{Binding CurrentAlfa}"
                                        CurrentBetta="{Binding CurrentBetta}"
                                        CurrentSegmentIndex="{Binding CurrentSegmentIndex}"
                                        CurrentSegmentT="{Binding CurrentSegmentT}"
                                        ToolXRaw="{Binding ToolXRaw}"
                                        ToolZRaw="{Binding ToolZRaw}"
                                        TargetXRaw="{Binding CurrentTargetX}"
                                        TargetZRaw="{Binding CurrentTargetZ}"
                                        Settings="{Binding AppSettings}"
                                        ShowPairLinks="{Binding ShowPairLinks}"
                                        ShowGrid="{Binding ShowGrid}" />
          </Grid>
        </Border>
        <Border x:Name="PlotResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="TelemetryPanel" Classes="card floating-panel" Width="320" Height="335" MinWidth="250" MinHeight="250"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="TelemetryPanelHeader" ColumnDefinitions="*,Auto">
              <TextBlock Text="Телеметрия" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Classes="ghost panel-close-btn" Click="HideTelemetryPanel_Click">✕</Button>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="3">
              <TextBlock Text="R:" Classes="muted"/>
              <TextBlock Grid.Column="1" Text="{Binding ToolR, StringFormat='{}{0:F1} мм'}" FontSize="18" />
              <TextBlock Grid.Row="1" Text="Z:" Classes="muted"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ToolZ, StringFormat='{}{0:F1} мм'}" FontSize="18" />
              <TextBlock Grid.Row="2" Text="X:" Classes="muted"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ToolX, StringFormat='{}{0:F1}'}" />
              <TextBlock Grid.Row="3" Text="Y:" Classes="muted"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ToolY, StringFormat='{}{0:F1}'}" />
              <TextBlock Grid.Row="4" Text="α:" Classes="muted"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentAlfa, StringFormat='{}{0:F1}°'}" />
              <TextBlock Grid.Row="5" Text="β:" Classes="muted"/>
              <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentBetta, StringFormat='{}{0:F1}°'}" />
              <TextBlock Grid.Row="6" Text="Xp:" Classes="muted" />
              <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CurrentXPuls}" />
              <TextBlock Grid.Row="7" Text="Yp:" Classes="muted" />
              <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CurrentYPuls}" />
              <TextBlock Grid.Row="8" Text="Zp:" Classes="muted" />
              <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CurrentZPuls}" />
            </Grid>
          </Grid>
        </Border>
        <Border x:Name="TelemetryResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="TopViewPanel" Classes="card floating-panel" Width="560" Height="320" MinWidth="420" MinHeight="240"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="TopViewPanelHeader" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="Вид сверху (X-Y)" Classes="muted" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost" ToolTip.Tip="Приблизить" Click="ZoomInTopView_Click">＋</Button>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Отдалить" Click="ZoomOutTopView_Click">－</Button>
                <Button Classes="ghost" ToolTip.Tip="Подогнать в окно" Click="FitTopView_Click">Fit</Button>
                <TextBlock x:Name="TopViewZoomText" Text="x1.00" Classes="muted" VerticalAlignment="Center" />
                <Button Classes="ghost panel-close-btn" Click="HideTopViewPanel_Click">✕</Button>
              </StackPanel>
            </Grid>
            <controls:SimulationTopViewControl Grid.Row="1" x:Name="TopViewPlot" Points="{Binding PointsForAnimation}" Progress="{Binding Progress}" />
          </Grid>
        </Border>
        <Border x:Name="TopViewResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="View2DPanel" Classes="card floating-panel" Width="740" Height="470" MinWidth="520" MinHeight="300"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
            <Grid x:Name="View2DPanelHeader" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="2D View (mm)" Classes="muted" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost" ToolTip.Tip="Zoom In" Click="ZoomIn2DView_Click">+</Button>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Zoom Out" Click="ZoomOut2DView_Click">-</Button>
                <Button Classes="ghost" ToolTip.Tip="Fit To Window" Click="Fit2DView_Click">Fit</Button>
                <TextBlock x:Name="View2DZoomText" Text="x1.00" Classes="muted" VerticalAlignment="Center" />
                <Button Classes="ghost panel-close-btn" Click="HideView2DPanel_Click">✕</Button>
              </StackPanel>
            </Grid>

            <Border Grid.Row="1" Classes="card" Padding="8,6">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,90,Auto,90,Auto,90,Auto,90,Auto,Auto" ColumnSpacing="8">
                  <TextBlock Text="Nozzle X" Classes="muted" VerticalAlignment="Center" />
                  <Slider Grid.Column="1" Minimum="0.00" Maximum="0.99"
                          Value="{Binding ElementName=View2DPlot, Path=NozzleAnchorX, Mode=TwoWay}" />

                  <TextBlock Grid.Column="2" Text="Nozzle Y" Classes="muted" VerticalAlignment="Center" />
                  <Slider Grid.Column="3" Minimum="0.00" Maximum="0.99"
                          Value="{Binding ElementName=View2DPlot, Path=NozzleAnchorY, Mode=TwoWay}" />

                  <TextBlock Grid.Column="4" Text="Manip X" Classes="muted" VerticalAlignment="Center" />
                  <Slider Grid.Column="5" Minimum="0.00" Maximum="0.70"
                          Value="{Binding ElementName=View2DPlot, Path=ManipulatorAnchorX, Mode=TwoWay}" />

                  <TextBlock Grid.Column="6" Text="Manip Y" Classes="muted" VerticalAlignment="Center" />
                  <Slider Grid.Column="7" Minimum="0.00" Maximum="0.99"
                          Value="{Binding ElementName=View2DPlot, Path=ManipulatorAnchorY, Mode=TwoWay}" />

                  <Button Grid.Column="8" Classes="ghost" Click="Reset2DCalibration_Click">Reset Cal</Button>
                  <Button Grid.Column="9" Classes="ghost" Click="AutoAlign2DCalibration_Click">Auto Cal</Button>
                </Grid>

                <Grid ColumnDefinitions="Auto,220,Auto,220" ColumnSpacing="8">
                  <TextBlock Text="Offset Z (mm)" Classes="muted" VerticalAlignment="Center" />
                  <Slider Grid.Column="1" Minimum="-5000" Maximum="5000"
                          Value="{Binding ElementName=View2DPlot, Path=VerticalOffsetMm, Mode=TwoWay}" />

                  <TextBlock Grid.Column="2" Text="Offset X (mm)" Classes="muted" VerticalAlignment="Center" />
                  <Slider Grid.Column="3" Minimum="-5000" Maximum="5000"
                          Value="{Binding ElementName=View2DPlot, Path=HorizontalOffsetMm, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                  <TextBlock Text="Reverse Path" Classes="muted" VerticalAlignment="Center" />
                  <ToggleButton Grid.Column="1"
                                IsChecked="{Binding ElementName=View2DPlot, Path=ReversePath, Mode=TwoWay}"
                                Classes="ghost"
                                VerticalAlignment="Center">Right → Left</ToggleButton>
                </Grid>
              </StackPanel>
            </Border>

            <controls:SimulationBlueprint2DControl Grid.Row="2" x:Name="View2DPlot"
                                                   Points="{Binding PointsForAnimation}"
                                                   Progress="{Binding Progress}"
                                                   Settings="{Binding AppSettings}"
                                                   CurrentAlfa="{Binding CurrentAlfa}"
                                                   ToolXRaw="{Binding ToolXRaw}"
                                                   ToolZRaw="{Binding ToolZRaw}"
                                                   TargetXRaw="{Binding CurrentTargetX}"
                                                   TargetZRaw="{Binding CurrentTargetZ}"
                                                   ShowGrid="{Binding ShowGrid}" />
          </Grid>
        </Border>
        <Border x:Name="View2DResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="View2DFactPanel" Classes="card floating-panel" Width="700" Height="420" MinWidth="500" MinHeight="280"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased" IsVisible="False">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="View2DFactPanelHeader" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="2D Fact (mm)" Classes="muted" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost" ToolTip.Tip="Zoom In" Click="ZoomIn2DFactView_Click">+</Button>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Zoom Out" Click="ZoomOut2DFactView_Click">-</Button>
                <Button Classes="ghost" ToolTip.Tip="Fit To Window" Click="Fit2DFactView_Click">Fit</Button>
                <TextBlock x:Name="View2DFactZoomText" Text="x1.00" Classes="muted" VerticalAlignment="Center" />
                <Button Classes="ghost panel-close-btn" Click="HideView2DFactPanel_Click">X</Button>
              </StackPanel>
            </Grid>

            <controls:SimulationBlueprint2DControl Grid.Row="1" x:Name="View2DFactPlot"
                                                   UseFactTelemetry="True"
                                                   Points="{Binding PointsForAnimation}"
                                                   Progress="{Binding Progress}"
                                                   Settings="{Binding AppSettings}"
                                                   CurrentAlfa="{Binding CurrentAlfa}"
                                                   ToolXRaw="{Binding ToolXRaw}"
                                                   ToolZRaw="{Binding ToolZRaw}"
                                                   TargetXRaw="{Binding CurrentTargetX}"
                                                   TargetZRaw="{Binding CurrentTargetZ}"
                                                   ShowGrid="{Binding ShowGrid}"
                                                   NozzleAnchorX="{Binding ElementName=View2DPlot, Path=NozzleAnchorX}"
                                                   NozzleAnchorY="{Binding ElementName=View2DPlot, Path=NozzleAnchorY}"
                                                   ManipulatorAnchorX="{Binding ElementName=View2DPlot, Path=ManipulatorAnchorX}"
                                                   ManipulatorAnchorY="{Binding ElementName=View2DPlot, Path=ManipulatorAnchorY}"
                                                   VerticalOffsetMm="{Binding ElementName=View2DPlot, Path=VerticalOffsetMm}"
                                                   HorizontalOffsetMm="{Binding ElementName=View2DPlot, Path=HorizontalOffsetMm}"
                                                   ReversePath="{Binding ElementName=View2DPlot, Path=ReversePath}" />
          </Grid>
        </Border>
        <Border x:Name="View2DFactResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased"
                IsVisible="False" />

        <Border x:Name="View2DPairPanel" Classes="card floating-panel" Width="820" Height="640" MinWidth="500" MinHeight="300"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased" IsVisible="False">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="View2DPairPanelHeader" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="2D Pair (1-2)" Classes="muted" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost" ToolTip.Tip="Zoom In" Click="ZoomIn2DPairView_Click">+</Button>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Zoom Out" Click="ZoomOut2DPairView_Click">-</Button>
                <Button Classes="ghost" ToolTip.Tip="Fit To Window" Click="Fit2DPairView_Click">Fit</Button>
                <TextBlock x:Name="View2DPairZoomText" Text="x1.00" Classes="muted" VerticalAlignment="Center" />
                <Button Classes="ghost panel-close-btn" Click="HideView2DPairPanel_Click">X</Button>
              </StackPanel>
            </Grid>

            <controls:SimulationPointPair2DControl Grid.Row="1" x:Name="View2DPairPlot"
                                                   Points="{Binding PointsForAnimation}"
                                                   Progress="{Binding Progress}"
                                                   CurrentSegmentIndex="{Binding CurrentSegmentIndex}"
                                                   CurrentSegmentT="{Binding CurrentSegmentT}"
                                                   Settings="{Binding AppSettings}"
                                                   ToolXRaw="{Binding ToolXRaw}"
                                                   ToolZRaw="{Binding ToolZRaw}"
                                                   TargetXRaw="{Binding CurrentTargetX}"
                                                   TargetZRaw="{Binding CurrentTargetZ}"
                                                   ShowGrid="{Binding ShowGrid}"
                                                   InvertHorizontal="{Binding ElementName=View2DPlot, Path=InvertHorizontal}"
                                                   ReferenceHeightMm="{Binding ElementName=View2DPlot, Path=ReferenceHeightMm}"
                                                   ManipulatorAnchorX="{Binding ElementName=View2DPlot, Path=ManipulatorAnchorX}"
                                                   ManipulatorAnchorY="{Binding ElementName=View2DPlot, Path=ManipulatorAnchorY}"
                                                   VerticalOffsetMm="{Binding ElementName=View2DPlot, Path=VerticalOffsetMm}"
                                                   HorizontalOffsetMm="{Binding ElementName=View2DPlot, Path=HorizontalOffsetMm}" />
          </Grid>
        </Border>
        <Border x:Name="View2DPairResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased"
                IsVisible="False" />

        <Border x:Name="View3DPanel" Classes="card floating-panel" Width="1160" Height="640" MinWidth="420" MinHeight="240" ClipToBounds="True"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="View3DPanelHeader" ColumnDefinitions="*,Auto">
              <TextBlock Text="3D визуализация" Classes="muted" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost panel-close-btn" Click="HideView3DPanel_Click">✕</Button>
            </Grid>
            <controls:Simulation3DControl Grid.Row="1" x:Name="Simulation3D"
                                          Points="{Binding PointsForAnimation}"
                                          Settings="{Binding AppSettings}"
                                          ShowGrid="{Binding ShowGrid}"
                                          ShowPairLinks="{Binding ShowPairLinks}"
                                          ToolXRaw="{Binding ToolXRaw}"
                                          ToolYRaw="{Binding ToolYRaw}"
                                          ToolZRaw="{Binding ToolZRaw}"
                                          NozzleOrientationMode="{Binding NozzleOrientationMode}"
                                          CurrentAlfa="{Binding CurrentAlfa}"
                                          CurrentBetta="{Binding CurrentBetta}" />
          </Grid>
        </Border>
        <Border x:Name="View3DResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />
      </Canvas>

      <Border Classes="card panel-launcher-strip" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Classes="ghost panel-launch-btn"
                  IsVisible="{Binding AppSettings.SimulationPanels.Access.Plot}"
                  ToolTip.Tip="Показать/скрыть профайлер R-Z"
                  Click="ShowPlotPanel_Click">Профиль</Button>
          <Button Classes="ghost panel-launch-btn"
                  IsVisible="{Binding AppSettings.SimulationPanels.Access.Telemetry}"
                  ToolTip.Tip="Показать/скрыть телеметрию"
                  Click="ShowTelemetryPanel_Click">Телеметрия</Button>
          <Button Classes="ghost panel-launch-btn"
                  IsVisible="{Binding AppSettings.SimulationPanels.Access.View2DPair}"
                  ToolTip.Tip="Показать/скрыть 2D (без сопла)"
                  Click="ShowView2DPairPanel_Click">2D Pair</Button>
          <Button Classes="ghost panel-launch-btn"
                  IsVisible="{Binding AppSettings.SimulationPanels.Access.View2D}"
                  ToolTip.Tip="Показать/скрыть 2D"
                  Click="ShowView2DPanel_Click">2D</Button>
          <Button Classes="ghost panel-launch-btn"
                  IsVisible="{Binding AppSettings.SimulationPanels.Access.View2DFact}"
                  ToolTip.Tip="Показать/скрыть 2D факт"
                  Click="ShowView2DFactPanel_Click">2D Fact</Button>
          <Button Classes="ghost panel-launch-btn"
                  IsVisible="{Binding AppSettings.SimulationPanels.Access.TopView}"
                  ToolTip.Tip="Показать/скрыть вид сверху"
                  Click="ShowTopViewPanel_Click">Top</Button>
          <Button Classes="ghost panel-launch-btn"
                  IsVisible="{Binding AppSettings.SimulationPanels.Access.View3D}"
                  ToolTip.Tip="Показать/скрыть 3D"
                  Click="ShowView3DPanel_Click">3D</Button>
          <Button Classes="ghost panel-launch-reset-btn" ToolTip.Tip="Сбросить окна" Click="ResetPanels_Click">↺</Button>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
