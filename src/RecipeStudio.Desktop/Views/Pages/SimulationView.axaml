<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RecipeStudio.Desktop.Controls"
             x:Class="RecipeStudio.Desktop.Views.Pages.SimulationView">

  <Grid Margin="18" RowDefinitions="Auto,*" RowSpacing="12">
    <Border Classes="card" Padding="14">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <StackPanel>
          <TextBlock Text="Симуляция процесса" Classes="h1"/>
          <TextBlock Text="{Binding RecipePath}" Classes="muted" />
        </StackPanel>

        <Button Grid.Column="1" Command="{Binding StepPreviousCommand}" Classes="ghost" VerticalAlignment="Center">⏮</Button>
        <Button Grid.Column="2" Command="{Binding PlayPauseCommand}" Classes="accent" VerticalAlignment="Center">▶ / ❚❚</Button>
        <Button Grid.Column="3" Command="{Binding StopCommand}" Classes="ghost" VerticalAlignment="Center">⏹</Button>
        <Button Grid.Column="4" Command="{Binding StepNextCommand}" Classes="ghost" VerticalAlignment="Center">⏭</Button>

        <ToggleButton Grid.Column="5" IsChecked="{Binding ShowPairLinks}" Classes="ghost" VerticalAlignment="Center">Сетка точек</ToggleButton>
        <ToggleButton Grid.Column="6" IsChecked="{Binding ShowGrid}" Classes="ghost" VerticalAlignment="Center">Фон. сетка</ToggleButton>

        <ToggleButton Grid.Column="7" IsChecked="{Binding IncludeSafePoints}" Classes="ghost" VerticalAlignment="Center">Safe в анимации</ToggleButton>
        <ToggleButton Grid.Column="8" IsChecked="{Binding SmoothMotion}" Classes="ghost" VerticalAlignment="Center">Плавная траектория</ToggleButton>

        <StackPanel Grid.Column="9" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="Скорость" Classes="muted" VerticalAlignment="Center"/>
          <Slider Minimum="0.2" Maximum="12" Width="140" Value="{Binding SpeedMultiplier}" />
        </StackPanel>

        <StackPanel Grid.Column="10" VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="{Binding ProgressPercent, StringFormat='Прогресс: {0}%'}" />
          <TextBlock Text="{Binding CurrentStepIndex, StringFormat='Шаг: {0}'}" Classes="muted" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Canvas x:Name="PanelsCanvas" ClipToBounds="True">
        <Border x:Name="PlotPanel" Classes="card floating-panel" Width="860" Height="520" MinWidth="520" MinHeight="340">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="PlotPanelHeader" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                  PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
              <TextBlock Text="PROFILE VIEWER (R-Z)" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Classes="ghost" ToolTip.Tip="Приблизить график" Click="ZoomInPlot_Click">＋</Button>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Отдалить график" Click="ZoomOutPlot_Click">－</Button>
                <Button Classes="ghost" ToolTip.Tip="Подогнать в окно" Click="FitPlot_Click">Fit</Button>
                <TextBlock x:Name="ZoomText" Text="x1.00" Classes="muted" VerticalAlignment="Center" />
                <Button Classes="ghost panel-close-btn" Click="HidePlotPanel_Click">✕</Button>
              </StackPanel>
            </Grid>

            <controls:RecipePlotControl Grid.Row="1" x:Name="RecipePlot"
                                        Points="{Binding PointsForPlot}"
                                        AnimationPoints="{Binding PointsForAnimation}"
                                        Progress="{Binding Progress}"
                                        Settings="{Binding AppSettings}"
                                        ShowPairLinks="{Binding ShowPairLinks}"
                                        ShowGrid="{Binding ShowGrid}" />
          </Grid>
        </Border>
        <Border x:Name="PlotResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="TelemetryPanel" Classes="card floating-panel" Width="290" Height="325" MinWidth="250" MinHeight="250">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="TelemetryPanelHeader" ColumnDefinitions="*,Auto"
                  PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
              <TextBlock Text="Телеметрия" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Classes="ghost panel-close-btn" Click="HideTelemetryPanel_Click">✕</Button>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="3">
              <TextBlock Text="R:" Classes="muted"/>
              <TextBlock Grid.Column="1" Text="{Binding ToolR, StringFormat='{}{0:F1} мм'}" FontSize="18" />
              <TextBlock Grid.Row="1" Text="Z:" Classes="muted"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ToolZ, StringFormat='{}{0:F1} мм'}" FontSize="18" />
              <TextBlock Grid.Row="2" Text="X:" Classes="muted"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ToolX, StringFormat='{}{0:F1}'}" />
              <TextBlock Grid.Row="3" Text="Y:" Classes="muted"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ToolY, StringFormat='{}{0:F1}'}" />
              <TextBlock Grid.Row="4" Text="α:" Classes="muted"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentAlfa, StringFormat='{}{0:F1}°'}" />
              <TextBlock Grid.Row="5" Text="β:" Classes="muted"/>
              <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentBetta, StringFormat='{}{0:F1}°'}" />
              <TextBlock Grid.Row="6" Text="Xp:" Classes="muted" />
              <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CurrentXPuls}" />
              <TextBlock Grid.Row="7" Text="Yp:" Classes="muted" />
              <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CurrentYPuls}" />
              <TextBlock Grid.Row="8" Text="Zp:" Classes="muted" />
              <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CurrentZPuls}" />
            </Grid>
          </Grid>
        </Border>
        <Border x:Name="TelemetryResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="TopViewPanel" Classes="card floating-panel" Width="560" Height="320" MinWidth="420" MinHeight="240">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="TopViewPanelHeader" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                  PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
              <TextBlock Text="Вид сверху (X-Y)" Classes="muted" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost" ToolTip.Tip="Приблизить" Click="ZoomInTopView_Click">＋</Button>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Отдалить" Click="ZoomOutTopView_Click">－</Button>
                <Button Classes="ghost" ToolTip.Tip="Подогнать в окно" Click="FitTopView_Click">Fit</Button>
                <TextBlock x:Name="TopViewZoomText" Text="x1.00" Classes="muted" VerticalAlignment="Center" />
                <Button Classes="ghost panel-close-btn" Click="HideTopViewPanel_Click">✕</Button>
              </StackPanel>
            </Grid>
            <controls:SimulationTopViewControl Grid.Row="1" x:Name="TopViewPlot" Points="{Binding PointsForAnimation}" Progress="{Binding Progress}" />
          </Grid>
        </Border>
        <Border x:Name="TopViewResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="View3DPanel" Classes="card floating-panel" Width="560" Height="320" MinWidth="420" MinHeight="240">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid x:Name="View3DPanelHeader" ColumnDefinitions="*,Auto"
                  PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
              <TextBlock Text="3D визуализация" Classes="muted" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost panel-close-btn" Click="HideView3DPanel_Click">✕</Button>
            </Grid>
            <controls:Simulation3DControl Grid.Row="1" x:Name="Simulation3D"
                                          Points="{Binding PointsForAnimation}"
                                          Settings="{Binding AppSettings}"
                                          ShowGrid="{Binding ShowGrid}"
                                          ShowPairLinks="{Binding ShowPairLinks}"
                                          ToolXRaw="{Binding ToolXRaw}"
                                          ToolYRaw="{Binding ToolYRaw}"
                                          ToolZRaw="{Binding ToolZRaw}"
                                          CurrentAlfa="{Binding CurrentAlfa}"
                                          CurrentBetta="{Binding CurrentBetta}" />
          </Grid>
        </Border>
        <Border x:Name="View3DResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />
      </Canvas>

      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть график" Click="ShowPlotPanel_Click">📈</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть телеметрию" Click="ShowTelemetryPanel_Click">🧾</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть вид сверху" Click="ShowTopViewPanel_Click">⬒</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть 3D" Click="ShowView3DPanel_Click">◪</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Сбросить окна" Click="ResetPanels_Click">↺</Button>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
