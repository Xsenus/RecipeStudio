<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RecipeStudio.Desktop.Controls"
             x:Class="RecipeStudio.Desktop.Views.Pages.SimulationView">

  <Grid Margin="18" RowDefinitions="Auto,*" RowSpacing="12">
    <Border Classes="card" Padding="14">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <StackPanel>
          <TextBlock Text="Симуляция процесса" Classes="h1"/>
          <TextBlock Text="{Binding RecipePath}" Classes="muted" />
        </StackPanel>

        <Button Grid.Column="1" Command="{Binding PlayPauseCommand}" Classes="accent" VerticalAlignment="Center">▶ / ❚❚</Button>
        <Button Grid.Column="2" Command="{Binding StopCommand}" Classes="ghost" VerticalAlignment="Center">⏹</Button>
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="Скорость" Classes="muted" VerticalAlignment="Center"/>
          <Slider Minimum="0.2" Maximum="3" Width="120" Value="{Binding SpeedMultiplier}" />
        </StackPanel>
        <TextBlock Grid.Column="4" Text="{Binding ProgressPercent, StringFormat='Прогресс: {0}%'}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="1.2*,1*" ColumnSpacing="12" RowDefinitions="1*,0.65*" RowSpacing="12">
      <Border Classes="card" Padding="10">
        <controls:RecipePlotControl Points="{Binding Points}" Progress="{Binding Progress}" Settings="{Binding AppSettings}" ShowPairLinks="True"/>
      </Border>

      <Border Grid.Column="1" Classes="card" Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="Телеметрия" FontSize="26" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="4">
            <TextBlock Text="R:" Classes="muted"/>
            <TextBlock Grid.Column="1" Text="{Binding ToolR, StringFormat='{}{0:F1} мм'}" FontSize="24" />

            <TextBlock Grid.Row="1" Text="Z:" Classes="muted"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ToolZ, StringFormat='{}{0:F1} мм'}" FontSize="24" />

            <TextBlock Grid.Row="2" Text="X:" Classes="muted"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ToolX, StringFormat='{}{0:F1}'}" />

            <TextBlock Grid.Row="3" Text="Y:" Classes="muted"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ToolY, StringFormat='{}{0:F1}'}" />

            <TextBlock Grid.Row="4" Text="α / β:" Classes="muted"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentAlfa, StringFormat='{}{0:F1}°'}" />

            <TextBlock Grid.Row="5" Text="" />
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentBetta, StringFormat='{}{0:F1}°'}" />

            <TextBlock Grid.Row="6" Text="Пульсы XYZ:" Classes="muted" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CurrentXPuls, StringFormat='X {0}'}" />
          </Grid>
          <TextBlock Text="{Binding CurrentYPuls, StringFormat='Y {0}'}" />
          <TextBlock Text="{Binding CurrentZPuls, StringFormat='Z {0}'}" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Classes="card" Padding="8">
        <StackPanel>
          <TextBlock Text="Вид сверху (X-Y)" Classes="muted" Margin="0,0,0,8" />
          <controls:SimulationTopViewControl Points="{Binding Points}" Progress="{Binding Progress}" MinHeight="210" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Classes="card" Padding="8">
        <StackPanel>
          <TextBlock Text="Псевдо-3D (изометрия)" Classes="muted" Margin="0,0,0,8" />
          <controls:SimulationIsometricControl Points="{Binding Points}" Progress="{Binding Progress}" MinHeight="210" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
