<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:RecipeStudio.Desktop.Controls"
             mc:Ignorable="d"
             x:Class="RecipeStudio.Desktop.Views.Pages.EditorView">

  <Grid RowDefinitions="Auto,*" Margin="18">

    <!-- Header -->
    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,12">
      <Button Command="{Binding BackCommand}" Classes="ghost back-arrow" Width="42" Height="34" Padding="0">
        <TextBlock Text="←" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Button>

      <TextBlock Grid.Column="1" Text="Редактор рецепта" Classes="h1" VerticalAlignment="Center" Margin="12,0,0,0" />

      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,8,0">
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть панель параметров" Click="ShowParametersPanel_Click">⚙</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть панель визуализации" Click="ShowVisualizationPanel_Click">📈</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть панель 2D Pair" Click="ShowPair2DPanel_Click">◫</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Показать/скрыть панель выбранной точки" Click="ShowSelectedPointPanel_Click">◎</Button>
        <Button Classes="ghost panel-icon-btn" ToolTip.Tip="Сбросить панели" Click="ResetPanels_Click">↺</Button>
      </StackPanel>

      <Button Grid.Column="3" Command="{Binding SaveCommand}" Classes="accent">Сохранить</Button>
    </Grid>

    <Grid Grid.Row="1">

      <!-- Left: table -->
      <Border Classes="card" Margin="0">
        <Grid RowDefinitions="Auto,*">

          <StackPanel Spacing="6" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Command="{Binding AddPointCommand}" Classes="good">+ Точка</Button>
              <Button Command="{Binding DuplicatePointCommand}" Classes="ghost">Дублировать</Button>
              <Button Click="DeleteSelectedPoint_Click"
                      IsEnabled="{Binding HasSelectedPoint}"
                      Classes="danger">Удалить</Button>
              <Button Command="{Binding MoveUpCommand}" Classes="ghost">↑</Button>
              <Button Command="{Binding MoveDownCommand}" Classes="ghost">↓</Button>
              <Button Command="{Binding RecalculateCommand}" Classes="ghost">Пересчитать</Button>
              <Button Command="{Binding ShowChartsCommand}" Classes="ghost">Графики</Button>

              <Button Command="{Binding ImportExcelCommand}" Classes="ghost">Импорт Excel</Button>
              <Button Command="{Binding ExportExcelCommand}" Classes="ghost">Экспорт Excel</Button>

              <TextBlock Text="{Binding Document.RecipeId, StringFormat='ID: {0}'}" Classes="muted" Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding ImportDiagnosticsSummary}" Classes="muted" TextWrapping="Wrap" MaxLines="2" ToolTip.Tip="{Binding ImportDiagnosticsSummary}" />
          </StackPanel>

          <DataGrid x:Name="PointsGrid"
                    Grid.Row="1"
                    Classes="editor-grid"
                    ItemsSource="{Binding Points}"
                    SelectedItem="{Binding SelectedPoint}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    IsReadOnly="False"
                    HeadersVisibility="All"
                    MinHeight="520"
                    FontSize="13"
                    RowHeight="34">

            <DataGrid.Columns>
              <DataGridTextColumn Binding="{Binding NPoint}" IsReadOnly="True" Width="45">
                <DataGridTextColumn.Header>
                  <TextBlock Text="#" Classes="grid-hdr" ToolTip.Tip="Порядковый номер точки" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTemplateColumn Width="25">
                <DataGridTemplateColumn.Header>
                  <Border Background="Transparent"
                          Cursor="Hand"
                          PointerPressed="BulkFlagHeader_PointerPressed"
                          Tag="Act">
                  <TextBlock Text="A" Classes="grid-hdr" ToolTip.Tip="Активность точки: 1 — участвует, 0 — выключена" />
                  </Border>
                </DataGridTemplateColumn.Header>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox Classes="a-green"
                              IsChecked="{Binding Act, Mode=TwoWay}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Width="25">
                <DataGridTemplateColumn.Header>
                  <TextBlock Text="S" Classes="grid-hdr hdr-yellow" ToolTip.Tip="Зона безопасности (Safe)" />
                </DataGridTemplateColumn.Header>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox Classes="s-yellow"
                              IsChecked="{Binding Safe, Mode=TwoWay}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Width="50">
                <DataGridTemplateColumn.Header>
                  <TextBlock Text="R" Classes="grid-hdr hdr-green" ToolTip.Tip="Радиальная координата, мм" />
                </DataGridTemplateColumn.Header>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Classes="rz-value"
                               Text="{Binding RCrd}"
                               Width="{Binding $parent[DataGridCell].Bounds.Width}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                  <DataTemplate>
                    <TextBox Classes="rz-edit"
                             Text="{Binding RCrd, Mode=TwoWay}"
                             Width="{Binding $parent[DataGridCell].Bounds.Width}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Width="50">
                <DataGridTemplateColumn.Header>
                  <TextBlock Text="Z" Classes="grid-hdr hdr-green" ToolTip.Tip="Высота Z, мм" />
                </DataGridTemplateColumn.Header>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Classes="rz-value"
                               Text="{Binding ZCrd}"
                               Width="{Binding $parent[DataGridCell].Bounds.Width}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                  <DataTemplate>
                    <TextBox Classes="rz-edit"
                             Text="{Binding ZCrd, Mode=TwoWay}"
                             Width="{Binding $parent[DataGridCell].Bounds.Width}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
              </DataGridTemplateColumn>

              <DataGridTextColumn Binding="{Binding ANozzle}" Width="50">
                <DataGridTextColumn.Header>
                  <TextBlock Text="a" Classes="grid-hdr" ToolTip.Tip="Диаметр сопла a, мм" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding Alfa}" Width="50">
                <DataGridTextColumn.Header>
                  <TextBlock Text="α" Classes="grid-hdr" ToolTip.Tip="Угол альфа, °" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding Betta}" Width="50">
                <DataGridTextColumn.Header>
                  <TextBlock Text="β" Classes="grid-hdr" ToolTip.Tip="Угол бета, °" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridCheckBoxColumn Binding="{Binding IsTop}" Width="45">
                <DataGridCheckBoxColumn.Header>
                  <Border Background="Transparent"
                          Cursor="Hand"
                          PointerPressed="BulkFlagHeader_PointerPressed"
                          Tag="Top">
                  <TextBlock Text="Top" Classes="grid-hdr hdr-blue" ToolTip.Tip="Сторона/уровень обработки (Top)" />
                  </Border>
                </DataGridCheckBoxColumn.Header>
              </DataGridCheckBoxColumn>

              <DataGridCheckBoxColumn Binding="{Binding Hidden}" Width="45">
                <DataGridCheckBoxColumn.Header>
                  <Border Background="Transparent"
                          Cursor="Hand"
                          PointerPressed="BulkFlagHeader_PointerPressed"
                          Tag="Hidden">
                  <TextBlock Text="Micro" Classes="grid-hdr" ToolTip.Tip="Микро-режим (скрытая/служебная точка)" />
                  </Border>
                </DataGridCheckBoxColumn.Header>
              </DataGridCheckBoxColumn>

              <DataGridTextColumn Binding="{Binding SpeedTable}" Width="45">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Speed" Classes="grid-hdr" ToolTip.Tip="ω — скорость стола, об/мин" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding TimeSec}" IsReadOnly="True" Width="45">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Time" Classes="grid-hdr" ToolTip.Tip="t, сек — время прохода" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding IceRate}" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Ice.R" Classes="grid-hdr hdr-violet" ToolTip.Tip="G_изм, кг/ч — фактический расход" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding IceGrind}" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Ice.G" Classes="grid-hdr hdr-violet" ToolTip.Tip="Степень помола/настройка льда" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding AirPressure}" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Air.P" Classes="grid-hdr hdr-violet" ToolTip.Tip="P, атм — давление воздуха" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding AirTemp}" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Air.T" Classes="grid-hdr hdr-violet" ToolTip.Tip="T, °C — температура воздуха" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding NozzleSpeedMmMin}" IsReadOnly="True" Width="50">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Vel" Classes="grid-hdr hdr-orange" ToolTip.Tip="V, мм/мин = round(2 * π * R * Speed / 60), где π = 3.14" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding RecommendedIceRate}" IsReadOnly="True" Width="50">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Flow" Classes="grid-hdr hdr-orange" ToolTip.Tip="Рекомендованный расход G, кг/ч" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding DX}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Xm" Classes="grid-hdr" ToolTip.Tip="Машинная координата X" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding DY}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Ym" Classes="grid-hdr" ToolTip.Tip="Машинная координата Y" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding DZ}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Zm" Classes="grid-hdr" ToolTip.Tip="Машинная координата Z" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding DA}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Am" Classes="grid-hdr" ToolTip.Tip="Машинная координата A" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding AB}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Bm" Classes="grid-hdr" ToolTip.Tip="Машинная координата B" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding Xr0}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Xr" Classes="grid-hdr hdr-red" ToolTip.Tip="Робот-координата X" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding Yx0}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Yr" Classes="grid-hdr hdr-red" ToolTip.Tip="Робот-координата Y" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding Zr0}" IsReadOnly="True" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Zr" Classes="grid-hdr hdr-red" ToolTip.Tip="Робот-координата Z" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding XPuls}" IsReadOnly="True" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Xp" Classes="grid-hdr hdr-deep-blue" ToolTip.Tip="Импульсы X" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding YPuls}" IsReadOnly="True" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Yp" Classes="grid-hdr hdr-deep-blue" ToolTip.Tip="Импульсы Y" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding ZPuls}" IsReadOnly="True" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Zp" Classes="grid-hdr hdr-deep-blue" ToolTip.Tip="Импульсы Z" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding APuls}" IsReadOnly="True" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Ap" Classes="grid-hdr hdr-deep-blue" ToolTip.Tip="Импульсы A" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding BPuls}" IsReadOnly="True" Width="65">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Bp" Classes="grid-hdr hdr-deep-blue" ToolTip.Tip="Импульсы B" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTextColumn Binding="{Binding Description}" Width="60">
                <DataGridTextColumn.Header>
                  <TextBlock Text="Desc" Classes="grid-hdr" ToolTip.Tip="Комментарий к точке" />
                </DataGridTextColumn.Header>
              </DataGridTextColumn>
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </Border>

      <!-- Movable / resizable panels overlay -->
      <Canvas x:Name="PanelsCanvas" ClipToBounds="True">
        <Border x:Name="ParametersPanel" Classes="card floating-panel"
                Width="390" Height="210" MinWidth="320" MinHeight="170"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Параметры" FontSize="16" FontWeight="SemiBold" />
              <Button Grid.Column="1" Classes="ghost panel-close-btn" Click="HideParametersPanel_Click">✕</Button>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,10,0,0">
              <TextBlock Text="Recipe" VerticalAlignment="Center" />
              <TextBox Grid.Column="1" Text="{Binding RecipeCode}" />

              <TextBlock Grid.Row="1" Text="Container" VerticalAlignment="Center" />
              <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding ContainerPresent}">Есть контейнер</CheckBox>

              <TextBlock Grid.Row="2" Text="D clamp form" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DClampForm}" />

              <TextBlock Grid.Row="3" Text="D clamp cont" VerticalAlignment="Center" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DClampCont}" />
            </Grid>
          </Grid>
        </Border>
        <Border x:Name="ParametersResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="VisualizationPanel" Classes="card floating-panel"
                Width="760" Height="520" MinWidth="520" MinHeight="360"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="PROFILE VIEWER (R-Z)" FontSize="16" FontWeight="SemiBold" />
              <Button Grid.Column="1" Classes="ghost panel-close-btn" Click="HideVisualizationPanel_Click">✕</Button>
            </Grid>

            <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" Margin="0,10,0,0">
              <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,0,0,8">
                <Button x:Name="LegendToggleButton" Classes="ghost" ToolTip.Tip="Показать/скрыть пояснения на графике" Click="ToggleLegend_Click">Пояснения: вкл</Button>
                <Button Grid.Column="1" x:Name="LinksToggleButton" Classes="ghost" ToolTip.Tip="Показать/скрыть вспомогательные связи Xp/Zp ↔ Xr/Zr" Click="TogglePairLinks_Click" Margin="8,0,0,0">Связи точек: выкл</Button>
                <Button Grid.Column="2" x:Name="EditorPlotTargetSideButton" Classes="ghost" ToolTip.Tip="Переключить ориентацию вида: исходная или зеркальная" Click="EditorPlotTargetSideButton_Click" Margin="8,0,0,0">Исходная</Button>
                <Button Grid.Column="3" x:Name="EditorPlotTargetCoverageButton" Classes="ghost" ToolTip.Tip="Переключить отображение контура: полное или частичное" Click="EditorPlotTargetCoverageButton_Click" Margin="8,0,0,0">Полная</Button>
              </Grid>

              <controls:RecipePlotControl Grid.Row="1" x:Name="RecipePlot" MinHeight="320"
                                         Points="{Binding Points}"
                                         SelectedPoint="{Binding SelectedPoint}"
                                         AnimationPoints="{Binding PointsForAnimation}"
                                         Progress="{Binding Progress}"
                                         IsPlaying="{Binding IsPlaying}"
                                         CurrentAlfa="{Binding CurrentAlfa}"
                                         CurrentBetta="{Binding CurrentBetta}"
                                         CurrentSegmentIndex="{Binding CurrentSegmentIndex}"
                                         CurrentSegmentT="{Binding CurrentSegmentT}"
                                         ToolXRaw="{Binding ToolXRaw}"
                                         ToolZRaw="{Binding ToolZRaw}"
                                         TargetXRaw="{Binding CurrentTargetX}"
                                         TargetZRaw="{Binding CurrentTargetZ}"
                                         Settings="{Binding AppSettings}"
                                         TargetDisplayMode="Full" />

              <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,14,Auto,Auto,Auto,Auto,*,Auto" Margin="0,8,0,0">
                <Button Command="{Binding PlayPauseCommand}" Classes="accent">▶ / ❚❚</Button>
                <Button Grid.Column="1" Command="{Binding StopCommand}" Classes="ghost">⏹</Button>

                <Button Grid.Column="3" Classes="ghost" ToolTip.Tip="Приблизить график" Click="ZoomInPlot_Click">＋</Button>
                <Button Grid.Column="4" Classes="ghost" ToolTip.Tip="Отдалить график" Click="ZoomOutPlot_Click">－</Button>
                <Button Grid.Column="5" Classes="ghost" ToolTip.Tip="Подогнать в окно" Click="FitPlot_Click">Fit</Button>
                <TextBlock Grid.Column="6" x:Name="ZoomText" Text="x1.00" VerticalAlignment="Center" Classes="muted" Margin="8,0,12,0"/>

                <TextBlock Grid.Column="7" Text="Скорость" VerticalAlignment="Center" Classes="muted" HorizontalAlignment="Right" Margin="0,0,8,0" />
                <Slider Grid.Column="8" Minimum="0.2" Maximum="3" Value="{Binding SpeedMultiplier}" Width="120" />
              </Grid>
            </Grid>
          </Grid>
        </Border>
        <Border x:Name="VisualizationResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="Pair2DPanel" Classes="card floating-panel"
                Width="760" Height="600" MinWidth="520" MinHeight="360"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="2D Pair (1-2)" FontSize="16" FontWeight="SemiBold" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Classes="ghost" ToolTip.Tip="Приблизить 2D Pair" Click="ZoomInPair2D_Click">+</Button>
                <Button Classes="ghost" ToolTip.Tip="Отдалить 2D Pair" Click="ZoomOutPair2D_Click">-</Button>
                <Button Classes="ghost" ToolTip.Tip="Подогнать в окно" Click="FitPair2D_Click">Fit</Button>
                <Button x:Name="EditorPair2DTargetSideButton" Classes="ghost" ToolTip.Tip="Переключить ориентацию вида: исходная или зеркальная" Click="EditorPair2DTargetSideButton_Click">Исходная</Button>
                <Button x:Name="EditorPair2DTargetCoverageButton" Classes="ghost" ToolTip.Tip="Переключить отображение контура: полное или частичное" Click="EditorPair2DTargetCoverageButton_Click">Полная</Button>
                <Button x:Name="EditorPair2DLinkToggleButton"
                        Classes="ghost"
                        ToolTip.Tip="Показать или скрыть красную опорную линию в 2D Pair"
                        Click="ToggleEditorPair2DLink_Click">Линия: вкл</Button>
                <TextBlock x:Name="Pair2DZoomText" Text="x1.00" VerticalAlignment="Center" Classes="muted" />
                <Button Classes="ghost panel-close-btn" Click="HidePair2DPanel_Click">✕</Button>
              </StackPanel>
            </Grid>

            <controls:SimulationPointPair2DControl Grid.Row="1" x:Name="Pair2DPlot"
                                                   Points="{Binding PointsForAnimation}"
                                                   PlotPoints="{Binding Points}"
                                                   SelectedPoint="{Binding SelectedPoint}"
                                                   TargetDisplayMode="Full"
                                                   Progress="{Binding Progress}"
                                                   IsPlaying="{Binding IsPlaying}"
                                                   CurrentSegmentIndex="{Binding CurrentSegmentIndex}"
                                                   CurrentSegmentT="{Binding CurrentSegmentT}"
                                                   Settings="{Binding AppSettings}"
                                                   CurrentAlfa="{Binding CurrentAlfa}"
                                                   CurrentBetta="{Binding CurrentBetta}"
                                                   ToolXRaw="{Binding ToolXRaw}"
                                                   ToolZRaw="{Binding ToolZRaw}"
                                                   TargetXRaw="{Binding CurrentTargetX}"
                                                   TargetZRaw="{Binding CurrentTargetZ}"
                                                   ShowGrid="True"
                                                   ShowPairLink="True"
                                                   InvertHorizontal="{Binding ElementName=RecipePlot, Path=InvertHorizontal}"
                                                   ReferenceHeightMm="{Binding AppSettings.SimulationPanels.Calibration2D.ReferenceHeightMm}"
                                                   PartWidthScalePercent="{Binding AppSettings.SimulationPanels.Calibration2D.PartWidthScalePercent}"
                                                   ManipulatorAnchorX="{Binding AppSettings.SimulationPanels.Calibration2D.ManipulatorAnchorX}"
                                                   ManipulatorAnchorY="{Binding AppSettings.SimulationPanels.Calibration2D.ManipulatorAnchorY}"
                                                   VerticalOffsetMm="{Binding AppSettings.SimulationPanels.Calibration2D.VerticalOffsetMm}"
                                                   HorizontalOffsetMm="{Binding AppSettings.SimulationPanels.Calibration2D.HorizontalOffsetMm}" />
          </Grid>
        </Border>
        <Border x:Name="Pair2DResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />

        <Border x:Name="SelectedPointPanel" Classes="card floating-panel"
                Width="540" Height="720" MinWidth="420" MinHeight="420"
                PointerPressed="Panel_PointerPressed" PointerMoved="Panel_PointerMoved" PointerReleased="Panel_PointerReleased">
          <Grid RowDefinitions="Auto,*,Auto">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="POINT DETAILS" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedPoint, TargetNullValue='Select a point in the table or plot.'}"
                           Classes="muted"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1" Classes="ghost panel-close-btn" Click="HideSelectedPointPanel_Click">✕</Button>
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <Border Classes="point-detail-group">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding SelectedPoint.NPoint, StringFormat='Point #{0}'}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedPoint.Description, TargetNullValue='Desc empty'}"
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding SelectedPoint.Place, StringFormat='Top: {0}'}"
                                   Classes="point-detail-caption"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding SelectedPoint.Safe, StringFormat='S: {0}'}"
                                   Classes="point-detail-caption"
                                   HorizontalAlignment="Right" />
                      </StackPanel>
                    </Grid>

                    <WrapPanel Orientation="Horizontal" ItemWidth="112">
                      <Border Classes="point-detail-stat" Margin="0,0,8,8">
                        <StackPanel Spacing="3">
                          <TextBlock Text="R" Classes="point-detail-caption" />
                          <TextBlock Text="{Binding SelectedPoint.RCrd, StringFormat='{}{0:0.###} мм'}" Classes="point-detail-value" />
                        </StackPanel>
                      </Border>
                      <Border Classes="point-detail-stat" Margin="0,0,8,8">
                        <StackPanel Spacing="3">
                          <TextBlock Text="Z" Classes="point-detail-caption" />
                          <TextBlock Text="{Binding SelectedPoint.ZCrd, StringFormat='{}{0:0.###} мм'}" Classes="point-detail-value" />
                        </StackPanel>
                      </Border>
                      <Border Classes="point-detail-stat" Margin="0,0,8,8">
                        <StackPanel Spacing="3">
                          <TextBlock Text="α" Classes="point-detail-caption" />
                          <TextBlock Text="{Binding SelectedPoint.Alfa, StringFormat='{}{0:0.###}°'}" Classes="point-detail-value" />
                        </StackPanel>
                      </Border>
                      <Border Classes="point-detail-stat" Margin="0,0,8,8">
                        <StackPanel Spacing="3">
                          <TextBlock Text="β" Classes="point-detail-caption" />
                          <TextBlock Text="{Binding SelectedPoint.Betta, StringFormat='{}{0:0.###}°'}" Classes="point-detail-value" />
                        </StackPanel>
                      </Border>
                    </WrapPanel>
                  </StackPanel>
                </Border>

                <ContentControl Content="{Binding SelectedPoint}">
                  <ContentControl.ContentTemplate>
                    <DataTemplate>
                      <StackPanel Spacing="12">
                        <Border Classes="point-detail-group">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Flags / Top" Classes="point-detail-group-title" />
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                              <TextBlock Text="#" Classes="point-detail-label" />
                              <TextBlock Grid.Column="1" Text="{Binding NPoint}" Classes="point-detail-value" />

                              <TextBlock Grid.Row="1" Text="Top" Classes="point-detail-label" />
                              <CheckBox Grid.Row="1" Grid.Column="1"
                                        Classes="point-detail-flag"
                                        IsChecked="{Binding IsTop, Mode=TwoWay}" />

                              <TextBlock Grid.Row="2" Text="A" Classes="point-detail-label" />
                              <CheckBox Grid.Row="2" Grid.Column="1"
                                        Classes="point-detail-flag"
                                        IsChecked="{Binding Act, Mode=TwoWay}" />

                              <TextBlock Grid.Row="3" Text="S" Classes="point-detail-label" />
                              <CheckBox Grid.Row="3" Grid.Column="1"
                                        Classes="point-detail-flag"
                                        IsChecked="{Binding Safe, Mode=TwoWay}" />

                              <TextBlock Grid.Row="4" Text="Micro" Classes="point-detail-label" />
                              <CheckBox Grid.Row="4" Grid.Column="1"
                                        Classes="point-detail-flag"
                                        IsChecked="{Binding Hidden, Mode=TwoWay}" />

                              <TextBlock Grid.Row="5" Text="Container" Classes="point-detail-label" />
                              <CheckBox Grid.Row="5" Grid.Column="1"
                                        Classes="point-detail-flag"
                                        IsChecked="{Binding Container, Mode=TwoWay}" />
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="point-detail-group">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Input" Classes="point-detail-group-title" />
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                              <TextBlock Text="R" Classes="point-detail-label" />
                              <NumericUpDown Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="-50000"
                                             Maximum="50000"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding RCrd, Mode=TwoWay}" />

                              <TextBlock Grid.Row="1" Text="Z" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="1" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="-50000"
                                             Maximum="50000"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding ZCrd, Mode=TwoWay}" />

                              <TextBlock Grid.Row="2" Text="a" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="2" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="0"
                                             Maximum="5000"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding ANozzle, Mode=TwoWay}" />

                              <TextBlock Grid.Row="3" Text="α" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="3" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="-360"
                                             Maximum="360"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding Alfa, Mode=TwoWay}" />

                              <TextBlock Grid.Row="4" Text="β" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="4" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="-360"
                                             Maximum="360"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding Betta, Mode=TwoWay}" />
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="point-detail-group">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Process" Classes="point-detail-group-title" />
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                              <TextBlock Text="Speed" Classes="point-detail-label" />
                              <NumericUpDown Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="0"
                                             Maximum="10000"
                                             Increment="1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding SpeedTable, Mode=TwoWay}" />

                              <TextBlock Grid.Row="1" Text="Ice.R" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="1" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="0"
                                             Maximum="10000"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding IceRate, Mode=TwoWay}" />

                              <TextBlock Grid.Row="2" Text="Ice.G" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="2" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="0"
                                             Maximum="10000"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding IceGrind, Mode=TwoWay}" />

                              <TextBlock Grid.Row="3" Text="Air.P" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="3" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="0"
                                             Maximum="1000"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding AirPressure, Mode=TwoWay}" />

                              <TextBlock Grid.Row="4" Text="Air.T" Classes="point-detail-label" />
                              <NumericUpDown Grid.Row="4" Grid.Column="1"
                                             Classes="point-detail-input"
                                             Minimum="-200"
                                             Maximum="1000"
                                             Increment="0.1"
                                             FormatString="0.###"
                                             ClipValueToMinMax="False"
                                             Value="{Binding AirTemp, Mode=TwoWay}" />
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="point-detail-group">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Calc" Classes="point-detail-group-title" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                              <Border Classes="point-detail-stat">
                                <StackPanel Spacing="3">
                                  <TextBlock Text="α rec" Classes="point-detail-caption" />
                                  <TextBlock Text="{Binding RecommendedAlfa, StringFormat='{}{0:0.###}°'}" Classes="point-detail-value" />
                                </StackPanel>
                              </Border>
                              <Border Grid.Column="1" Classes="point-detail-stat">
                                <StackPanel Spacing="3">
                                  <TextBlock Text="Flow" Classes="point-detail-caption" />
                                  <TextBlock Text="{Binding RecommendedIceRate, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                </StackPanel>
                              </Border>
                              <Border Grid.Row="1" Classes="point-detail-stat">
                                <StackPanel Spacing="3">
                                  <TextBlock Text="Time" Classes="point-detail-caption" />
                                  <TextBlock Text="{Binding TimeSec, StringFormat='{}{0:0.###} c'}" Classes="point-detail-value" />
                                </StackPanel>
                              </Border>
                              <Border Grid.Row="1" Grid.Column="1" Classes="point-detail-stat">
                                <StackPanel Spacing="3">
                                  <TextBlock Text="Vel" Classes="point-detail-caption" />
                                  <TextBlock Text="{Binding NozzleSpeedMmMin, StringFormat='{}{0:0.###} мм/мин'}" Classes="point-detail-value" />
                                </StackPanel>
                              </Border>
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="point-detail-group">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Robot / Machine" Classes="point-detail-group-title" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                              <Border Classes="point-detail-stat">
                                <StackPanel Spacing="6">
                                  <TextBlock Text="Robot" Classes="point-detail-caption" />
                                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                    <TextBlock Text="Xr" Classes="point-detail-label" />
                                    <TextBlock Grid.Column="1" Text="{Binding Xr0, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                    <TextBlock Grid.Row="1" Text="Yr" Classes="point-detail-label" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Yx0, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                    <TextBlock Grid.Row="2" Text="Zr" Classes="point-detail-label" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Zr0, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  </Grid>
                                </StackPanel>
                              </Border>

                              <Border Grid.Column="1" Classes="point-detail-stat">
                                <StackPanel Spacing="6">
                                  <TextBlock Text="Machine" Classes="point-detail-caption" />
                                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                    <TextBlock Text="Xm" Classes="point-detail-label" />
                                    <TextBlock Grid.Column="1" Text="{Binding DX, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                    <TextBlock Grid.Row="1" Text="Ym" Classes="point-detail-label" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DY, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                    <TextBlock Grid.Row="2" Text="Zm" Classes="point-detail-label" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DZ, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                    <TextBlock Grid.Row="3" Text="Am" Classes="point-detail-label" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DA, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                    <TextBlock Grid.Row="4" Text="Bm" Classes="point-detail-label" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AB, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  </Grid>
                                </StackPanel>
                              </Border>
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="point-detail-group">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Pulses" Classes="point-detail-group-title" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                              <Border Classes="point-detail-stat">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                  <TextBlock Text="Xp" Classes="point-detail-label" />
                                  <TextBlock Grid.Column="1" Text="{Binding XPuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  <TextBlock Grid.Row="1" Text="Yp" Classes="point-detail-label" />
                                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding YPuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  <TextBlock Grid.Row="2" Text="Zp" Classes="point-detail-label" />
                                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ZPuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                </Grid>
                              </Border>
                              <Border Grid.Column="1" Classes="point-detail-stat">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                  <TextBlock Text="Ap" Classes="point-detail-label" />
                                  <TextBlock Grid.Column="1" Text="{Binding APuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  <TextBlock Grid.Row="1" Text="Bp" Classes="point-detail-label" />
                                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BPuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  <TextBlock Grid.Row="2" Text="Top" Classes="point-detail-label" />
                                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TopPuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  <TextBlock Grid.Row="3" Text="Low" Classes="point-detail-label" />
                                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LowPuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                  <TextBlock Grid.Row="4" Text="Clamp" Classes="point-detail-label" />
                                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ClampPuls, StringFormat='{}{0:0.###}'}" Classes="point-detail-value" />
                                </Grid>
                              </Border>
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="point-detail-group">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Desc" Classes="point-detail-group-title" />
                            <TextBox Classes="point-detail-input"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="90"
                                     Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </DataTemplate>
                  </ContentControl.ContentTemplate>
                </ContentControl>
              </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
              <TextBlock Text="Changes apply immediately. Plot recalculates automatically."
                         Classes="muted"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center"
                         Margin="0,0,12,0" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding MoveUpCommand}" Classes="ghost">↑</Button>
                <Button Command="{Binding MoveDownCommand}" Classes="ghost">↓</Button>
                <Button Click="DeleteSelectedPoint_Click"
                        IsEnabled="{Binding HasSelectedPoint}"
                        Classes="danger">Удалить</Button>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
        <Border x:Name="SelectedPointResizeHandle" Classes="panel-resize-handle"
                PointerPressed="ResizeHandle_PointerPressed" PointerMoved="ResizeHandle_PointerMoved" PointerReleased="ResizeHandle_PointerReleased" />
      </Canvas>
    </Grid>
  </Grid>
</UserControl>
