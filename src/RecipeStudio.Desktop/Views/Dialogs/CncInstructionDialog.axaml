<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RecipeStudio.Desktop.Views.Dialogs.CncInstructionDialog"
        Width="1460"
        Height="860"
        MinWidth="1040"
        MinHeight="640"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Title="&#1063;&#1055;&#1059;-&#1080;&#1085;&#1089;&#1090;&#1088;&#1091;&#1082;&#1094;&#1080;&#1103;">

  <Border Classes="modal-surface" Background="#0B1B3E" BorderBrush="#304766" CornerRadius="14">
    <Grid RowDefinitions="Auto,*">
      <Border Background="#0D1D45" Padding="20,14" PointerPressed="Header_PointerPressed">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="#17376C" CornerRadius="8" Padding="10,6">
              <TextBlock Text="CNC" Foreground="#59A4FF" FontSize="15" FontWeight="Bold" />
            </Border>
            <TextBlock Text="&#1063;&#1055;&#1059;-&#1080;&#1085;&#1089;&#1090;&#1088;&#1091;&#1082;&#1094;&#1080;&#1103;" FontSize="30" FontWeight="SemiBold" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
            <Button Classes="ghost" Click="Export_Click">&#1069;&#1082;&#1089;&#1087;&#1086;&#1088;&#1090; Excel</Button>
            <Button Classes="window-btn" Click="Close_Click">&#10005;</Button>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="16">
        <DataGrid x:Name="CalcGrid"
                  Classes="editor-grid"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="All"
                  MinHeight="420"
                  FontSize="13"
                  RowHeight="34" />
      </Grid>
    </Grid>
  </Border>
</Window>
