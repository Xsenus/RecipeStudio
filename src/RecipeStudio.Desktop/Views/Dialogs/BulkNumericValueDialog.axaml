<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RecipeStudio.Desktop.Views.Dialogs.BulkNumericValueDialog"
        Width="560"
        Height="250"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Title="Массовое изменение">

  <Border BorderBrush="#2A3142" BorderThickness="1" Background="#0F1420">
    <Grid RowDefinitions="Auto,*">
      <Border Background="#111827" Padding="12,8" PointerPressed="Header_PointerPressed">
        <TextBlock x:Name="TitleBlock" FontSize="18" FontWeight="Bold" />
      </Border>

      <Grid Grid.Row="1" Margin="16" RowDefinitions="Auto,Auto,Auto">
        <TextBlock x:Name="MessageBlock"
                   TextWrapping="Wrap"
                   Foreground="#A8B3CF" />

        <StackPanel Grid.Row="1" Margin="0,14,0,0" Spacing="6">
          <TextBlock Text="Значение" Foreground="#A8B3CF" />
          <NumericUpDown x:Name="ValueBox"
                         Classes="point-detail-input"
                         Minimum="-50000"
                         Maximum="50000"
                         Increment="0.1"
                         FormatString="0.###"
                         ClipValueToMinMax="False" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
          <Button x:Name="ApplyButton"
                  Classes="accent"
                  Width="180"
                  Height="40"
                  Padding="12,0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Click="Apply_Click">Установить для всех</Button>
          <Button x:Name="CancelButton"
                  Width="140"
                  Height="40"
                  Padding="12,0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Click="Cancel_Click">Отмена</Button>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
